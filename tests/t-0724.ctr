Out write: ['Test object'], stop.
>> a := Object new. 

a on: ['item:'] do: { :file
	own file := file. 
}.

a on: ['item'] do: {
	<- own file.
}.

>> f := File new: ['/tmp/aaa.txt'].
a item: f.
Out write: a item, stop.
a save-as: ['/tmp/a.bin'].
Out write: ['========== RELOADING SNAP:'], stop.
>> b := Object load-from: ['/tmp/a.bin'].
Out write: b item, stop.
