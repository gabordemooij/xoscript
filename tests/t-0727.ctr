Server init.
>> f := Format new: ['%d'].
>> a := Blob new: 4.
a bytes: ( List new ; Bin b00000101 ; Hx x0A ; Bin b10000001 ; 0).
>> b := Blob new: 4.
b bytes: ( List new ; Bin b00000110 ; Hx x0A ; Bin b10000000 ; 0).
a from: 0 length: 3, each: { :i :byte
	Out write: ( f apply-int: byte ) , stop.
}.
a ^ b.
a from: 0 length: 3, each: { :i :byte
	Out write: ( f apply-int: byte ) , stop.
}.
a ^ b.
a from: 0 length: 3, each: { :i :byte
	Out write: ( f apply-int: byte ) , stop.
}.
a free.
b free.

{ a ^ Object. } except: { :e Out write: e, stop. }, start.
