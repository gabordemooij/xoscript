Out write: ['Test object'], stop.
>> a := Object new. 

a on: ['item:'] do: { :moment
	own moment := moment. 
}.

a on: ['item'] do: {
	<- own moment.
}.

>> today := Moment new zone: ['CEST'], year: 2026, month: 7.
a item: today.
Out write: a item, stop.
a save-as: ['/tmp/a.bin'].
Out write: ['========== RELOADING SNAP:'], stop.
>> b := Object load-from: ['/tmp/a.bin'].
Out write: b item, stop.
