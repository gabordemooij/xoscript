# test buffers PKI/Sign 
Server init.

>> long := ( List new fill: 1000 with: ['a'] ) combine: [''].

# sign a message
Out write: ( 
	Vault sign: ['abc'] with: long
), stop.

Out write: ( 
	Vault
		check: ['abc'] 
		signature: long 
		with: long
), stop.

Out write: (
	Vault password-hash: long verify: long
), stop.
