Out write: ['Test object'], stop.
>> a := Object new. 

a on: ['state:'] do: { :list
	own list := list. 
}.

a on: ['state'] do: {
	Out write: own list, stop.
}.

a state: ( List new ; ['listitem'] ; ['item2'] ).
a state.

a save-as: ['/tmp/a.bin'].
Out write: ['========== RELOADING SNAP:'], stop.
>> b := Object load-from: ['/tmp/a.bin'].
b state.