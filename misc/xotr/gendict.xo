>> a := File new: ( Program argument: 2 ), read split: ['\n'].
>> b := File new: ( Program argument: 3 ), read split: ['\n'].

String on: ['part'] do: {
	<- ((self split: ['"']) ? 1).
}. 

a each: { :i :src
	(src find: ['#define'], None?) continue.
	>> tr := b position: i.
	Out write: ['t "a" "b"'] a src part b tr part, stop.
}.


